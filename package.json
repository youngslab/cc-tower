{
  "name": "cc-tower",
  "version": "1.1.1",
  "description": "Claude Code Session Control Tower — monitor and interact with multiple Claude Code sessions in tmux",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "cc-tower": "./bin/cc-tower.js",
    "popmux-go": "./bin/popmux-go"
  },
  "files": [
    "bin/",
    "dist/",
    "hooks/"
  ],
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "keywords": [
    "claude",
    "tmux",
    "session",
    "monitor",
    "tui"
  ],
  "author": "jaeyoungs",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "commander": "^12.1.0",
    "execa": "^9.5.3",
    "ink": "^5.2.0",
    "js-yaml": "^4.1.0",
    "node-notifier": "^10.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
